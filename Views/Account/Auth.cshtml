                    <a href="#" onclick="switchTab('login')" data-i18n="auth.loginNow">Đăng nhập ngay</a>
                </p>
            </div>

        </div><!-- /auth-card -->
    </div><!-- /auth-page -->

    <script>
        /* ── Auth guard: already logged in → go to index ── */
        (function () {
            if (localStorage.getItem('filmix_user')) location.replace('/');
        })();

        /* ── Read ?mode= from URL ── */
        (function () {
            const p = new URLSearchParams(window.location.search);
            if (p.get('mode') === 'signup') switchTab('signup');
        })();

        /* ── Tab switch ── */
        function switchTab(tab) {
            document.querySelectorAll('.auth-tab, .auth-panel').forEach(el => el.classList.remove('active'));
            document.getElementById('tab' + cap(tab)).classList.add('active');
            document.getElementById('panel' + cap(tab)).classList.add('active');
            return false;
        }
        function cap(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

        /* ── Toggle password visibility ── */
        function togglePw(inputId, btn) {
            const input = document.getElementById(inputId);
            const isText = input.type === 'text';
            input.type = isText ? 'password' : 'text';
            btn.querySelector('svg').style.opacity = isText ? '1' : '.5';
        }

        /* ── Validation helpers ── */
        function validateEmail(input, msgId) {
            const ok = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(input.value.trim());
            const msg = document.getElementById(msgId);
            if (!input.value) { input.className = 'form-input'; msg.className = 'form-msg'; return; }
            if (ok) {
                input.className = 'form-input valid';
                msg.className = 'form-msg success'; msg.textContent = 'Email hợp lệ';
            } else {
                input.className = 'form-input invalid';
                msg.className = 'form-msg error'; msg.textContent = 'Email không hợp lệ';
            }
        }

        function validateName(input) {
            const ok = input.value.trim().length >= 2;
            input.className = input.value ? (ok ? 'form-input valid' : 'form-input invalid') : 'form-input';
        }

        function validatePwBasic(input) {
            input.className = input.value.length >= 6 ? 'form-input valid' : (input.value ? 'form-input invalid' : 'form-input');
        }

        function checkPwStrength(input) {
            const val = input.value;
            const bar = document.getElementById('pwBar');
            const msg = document.getElementById('pwStrengthMsg');
            let score = 0;
            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;
            const levels = [
                { w: '0%',   bg: 'transparent', text: '' },
                { w: '25%',  bg: '#e50914',     text: 'Yếu' },
                { w: '50%',  bg: '#ff9f43',     text: 'Trung bình' },
                { w: '75%',  bg: '#ffd32a',     text: 'Tốt' },
                { w: '100%', bg: '#2dcc70',     text: 'Mạnh' },
            ];
            const lv = levels[score];
            bar.style.width = lv.w;
            bar.style.background = lv.bg;
            msg.textContent = lv.text;
            msg.className = score > 0 ? (score >= 3 ? 'form-msg success' : 'form-msg error') : 'form-msg';
            input.className = val.length >= 8 ? 'form-input valid' : (val ? 'form-input invalid' : 'form-input');
        }

        function checkPwMatch(input) {
            const pw = document.getElementById('signupPw').value;
            const msg = document.getElementById('pwMatchMsg');
            if (!input.value) { input.className = 'form-input'; msg.className = 'form-msg'; return; }
            if (input.value === pw) {
                input.className = 'form-input valid';
                msg.className = 'form-msg success'; msg.textContent = 'Mật khẩu khớp';
            } else {
                input.className = 'form-input invalid';
                msg.className = 'form-msg error'; msg.textContent = 'Mật khẩu chưa khớp';
            }
        }

        /* ── Toast notification ── */
        function showToast(message, type = 'success') {
            const t = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const msgEl = document.getElementById('toastMsg');
            icon.textContent = type === 'success' ? '✓' : '✕';
            msgEl.textContent = message;
            t.className = `toast ${type} show`;
            setTimeout(() => t.classList.remove('show'), 3500);
        }

        /* ── Loading spinner ── */
        function setLoading(btn, loading) {
            btn.classList.toggle('loading', loading);
            btn.disabled = loading;
        }

        /* ── Social login ── */
        function socialLogin(provider) {
            showToast('Đang kết nối tới ' + provider + '...', 'success');
        }

        /* ── Handle Login ── */
        function handleLogin() {
            const email = document.getElementById('loginEmail').value.trim();
            const pw = document.getElementById('loginPw').value;
            const btn = document.querySelector('#panelLogin .btn-auth');

            if (!email || !pw) { showToast('Vui lòng điền đầy đủ thông tin', 'error'); return; }

            setLoading(btn, true);
            setTimeout(() => {
                setLoading(btn, false);
                localStorage.setItem('filmix_user', JSON.stringify({ name: email.split('@@')[0], email }));
                showToast('Đăng nhập thành công!', 'success');
                setTimeout(() => { window.location.href = '/'; }, 1800);
            }, 1600);
        }

        /* ── Handle Signup ── */
        function handleSignup() {
            const name = document.getElementById('signupName').value.trim();
            const email = document.getElementById('signupEmail').value.trim();
            const pw = document.getElementById('signupPw').value;
            const pwConf = document.getElementById('signupPwConfirm').value;
            const agree = document.getElementById('agreeTerms').checked;
            const btn = document.querySelector('#panelSignup .btn-auth');

            if (!name || !email || !pw || !pwConf) { showToast('Vui lòng điền đầy đủ thông tin', 'error'); return; }
            if (pw !== pwConf) { showToast('Mật khẩu không khớp', 'error'); return; }
            if (!agree) { showToast('Bạn cần đồng ý với điều khoản', 'error'); return; }

            setLoading(btn, true);
            setTimeout(() => {
                setLoading(btn, false);
                localStorage.setItem('filmix_user', JSON.stringify({ name, email }));
                showToast('Đăng ký thành công!', 'success');
                setTimeout(() => { window.location.href = '/'; }, 2000);
            }, 1800);
        }
    </script>
</body>

</html>
