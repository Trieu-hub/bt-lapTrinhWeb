            </div>
            <div class="posters-row">
                <img src="~/images/auth/ap11.jpg" alt="" /><img
                    src="~/images/auth/ap12.jpg" alt="" />
                <img src="~/images/auth/ap13.jpg" alt="" /><img
                    src="~/images/auth/ap14.jpg" alt="" />
                <img src="~/images/auth/ap15.jpg" alt="" /><img
