@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FILMIX — Đăng Nhập / Đăng Ký</title>
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <script src="~/js/i18n.js"></script>
    <style>
        /* Extra auth-page animations not in main CSS */
        .auth-card__logo {
            animation: logoGlow 3s ease-in-out infinite alternate;
        }

        @@keyframes logoGlow {
            from {
                text-shadow: 0 0 20px rgba(229, 9, 20, .5);
            }

            to {
                text-shadow: 0 0 50px rgba(229, 9, 20, .9), 0 0 80px rgba(229, 9, 20, .3);
            }
        }

        /* Floating poster rows */
        .auth-page__posters {
            display: grid;
            grid-template-rows: repeat(2, 1fr);
        }

        .posters-row {
            display: flex;
            gap: 3px;
            overflow: hidden;
        }

        .posters-row img {
            width: 150px;
            height: 220px;
            object-fit: cover;
            flex-shrink: 0;
            filter: saturate(.2) brightness(.45);
        }

        .posters-row:nth-child(1) {
            animation: slideLeft 25s linear infinite;
        }

        .posters-row:nth-child(2) {
            animation: slideRight 30s linear infinite;
        }

        @@keyframes slideLeft {
            from {
                transform: translateX(0);
            }

            to {
                transform: translateX(-50%);
            }
        }

        @@keyframes slideRight {
            from {
                transform: translateX(-50%);
            }

            to {
                transform: translateX(0);
            }
        }

        /* Password strength bar */
        .pw-strength {
            height: 3px;
            background: var(--border);
            border-radius: 2px;
            margin-top: 6px;
            overflow: hidden;
        }

        .pw-strength__bar {
            height: 100%;
            width: 0;
            border-radius: 2px;
            transition: width .4s ease, background .4s;
        }

        /* Error / success messages */
        .form-msg {
            font-size: .78rem;
            margin-top: 5px;
            display: none;
        }

        .form-msg.error {
            color: #ff6b6b;
            display: block;
        }

        .form-msg.success {
            color: #6bffb8;
            display: block;
        }

        /* Input valid/invalid states */
        .form-input.valid {
            border-color: #2dcc70;
        }

        .form-input.invalid {
            border-color: #ff6b6b;
        }

        /* Back to home link */
        .back-home {
            position: fixed;
            top: 24px;
            left: 28px;
            z-index: 20;
            display: flex;
            align-items: center;
            gap: 7px;
            color: rgba(255, 255, 255, .55);
            font-size: .8rem;
            font-weight: 600;
            letter-spacing: .5px;
            transition: color .25s;
        }

        .back-home:hover {
            color: var(--white);
        }

        .back-home svg {
            flex-shrink: 0;
        }

        /* Loading spinner on btn */
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .btn-auth.loading .btn-text {
            display: none;
        }

        .btn-auth .spinner {
            display: none;
            width: 18px;
            height: 18px;
            border: 2px solid rgba(255, 255, 255, .3);
            border-top-color: var(--white);
            border-radius: 50%;
            animation: spin .7s linear infinite;
        }

        .btn-auth.loading .spinner {
            display: block;
        }

        /* Toast notification */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(80px);
            background: #1e1e1e;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 14px 24px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: .88rem;
            font-weight: 500;
            box-shadow: 0 12px 40px rgba(0, 0, 0, .6);
            transition: transform .4s var(--ease);
            z-index: 9998;
            white-space: nowrap;
        }

        .toast.show {
            transform: translateX(-50%) translateY(0);
        }

        .toast.success {
            border-left: 3px solid #2dcc70;
        }

        .toast.error {
            border-left: 3px solid #ff6b6b;
        }

        .toast-icon {
            font-size: 1.1rem;
        }
    </style>
</head>

<body>

    <!-- Back to home -->
    <a asp-controller="Home" asp-action="Index" class="back-home">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
        </svg>
