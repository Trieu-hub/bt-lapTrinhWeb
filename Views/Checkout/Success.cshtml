@model untitled1.Models.Entities.Order
@{
    ViewData["Title"] = "Đặt Hàng Thành Công - FILMIX";
}

<div class="checkout-success" style="background: #141414; color: #fff; min-height: 100vh; padding: 120px 5% 80px 5%; font-family: 'Outfit', sans-serif; display: flex; align-items: center; justify-content: center;">
    <div style="max-width: 650px; width: 100%; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 20px; padding: 40px; backdrop-filter: blur(10px); box-shadow: 0 20px 50px rgba(0,0,0,0.5); text-align: center;">
        
        <!-- Success Icon -->
        <div style="background: rgba(70, 211, 105, 0.1); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px auto; color: #46d369;">
            <svg width="45" height="45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        </div>

        <h1 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 10px; color: #fff;">
            Cảm Ơn Bạn Đã Đặt Hàng!
        </h1>
        <p style="color: #aaa; font-size: 1rem; margin-bottom: 30px;">
            Đơn hàng của bạn đã được ghi nhận và xử lý thành công.
        </p>

        <!-- Bill Details Card -->
        <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 25px; text-align: left; margin-bottom: 35px; display: grid; gap: 15px;">
            <h3 style="margin: 0; font-size: 1.1rem; font-weight: 700; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">
                Chi Tiết Hóa Đơn #@Model.Id
            </h3>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; font-size: 0.9rem; color: #ccc;">
                <span>Ngày đặt:</span>
                <strong style="text-align: right; color: #fff;">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</strong>

                <span>Họ và tên:</span>
                <strong style="text-align: right; color: #fff;">@Model.CustomerName</strong>

                <span>Email khách hàng:</span>
                <strong style="text-align: right; color: #fff;">@Model.CustomerEmail</strong>

                <span>Số điện thoại:</span>
                <strong style="text-align: right; color: #fff;">@Model.PhoneNumber</strong>

                <span>Trạng thái thanh toán:</span>
                <strong style="text-align: right; color: #46d369;">Đã hoàn thành</strong>
            </div>

            <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.08); margin: 5px 0;" />

            <!-- Items summary -->
            <div style="display: grid; gap: 10px;">
                @foreach (var item in Model.OrderItems)
                {
                    <div style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                        <span style="color: #ccc;">@item.Movie.Title <span style="color: #666;">(x@item.Quantity)</span></span>
                        <strong style="color: #fff;">@((item.Price * item.Quantity).ToString("N0")) đ</strong>
                    </div>
                }
            </div>

            <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.08); margin: 5px 0;" />

            <div style="display: flex; justify-content: space-between; font-size: 1.1rem; font-weight: 700;">
                <span>Tổng cộng:</span>
                <strong style="color: #46d369;">@Model.Total.ToString("N0") VNĐ</strong>
            </div>
        </div>

        <!-- Call To Actions -->
        <div style="display: flex; gap: 15px; justify-content: center;">
            <a asp-controller="Order" asp-action="Index" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #fff; text-decoration: none; padding: 12px 25px; border-radius: 6px; font-weight: 700; font-size: 0.95rem; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)'" onmouseout="this.style.background='rgba(255,255,255,0.08)'">
                Đơn Hàng Của Tôi
            </a>
            <a asp-controller="Home" asp-action="Index" style="background: #e50914; color: #fff; text-decoration: none; padding: 12px 25px; border-radius: 6px; font-weight: 700; font-size: 0.95rem; transition: all 0.2s;" onmouseover="this.style.transform='scale(1.03)'; this.style.filter='brightness(1.1)';" onmouseout="this.style.transform='none'; this.style.filter='none';">
                Về Trang Chủ
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Force header solid state
        const nav = document.getElementById('nav');
        if (nav) nav.classList.add('scrolled');
    </script>
}
