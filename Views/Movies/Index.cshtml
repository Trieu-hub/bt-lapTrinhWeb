@model IEnumerable<Movie>
@{
    ViewData["Title"] = "Phim Lẻ - FILMIX";
}

<!-- Self-contained custom CSS link -->
<link rel="stylesheet" href="~/css/movies.css" asp-append-version="true" />

<!-- ══════════════════════════════════════
     HERO SECTION: INTERSTELLAR
     ══════════════════════════════════════ -->
<section class="hero hero--movies movies-fade-in">
    <div class="hero__bg" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 60%, transparent 100%), url('/images/movies/7.jpg') center/cover;"></div>
    <div class="hero__inner" style="align-items: flex-start; text-align: left; padding-left: 5%;">
        <div class="hero__content" style="max-width: 650px; margin-left: 0;">
            <div class="hero__badge" style="background: rgba(59, 130, 246, 0.25); border: 1px solid rgba(59, 130, 246, 0.4); color: #60a5fa;" data-i18n="ui.hot">PHIM ĐIỆN ẢNH</div>
            <h1 class="hero__title" style="font-size: 5rem; letter-spacing: -2px; font-weight: 900;">INTER<br><span style="color: #60a5fa;">STELLAR</span></h1>
            <p class="hero__sub" style="margin-left: 0; color: #d1d5db; line-height: 1.6;">
                Một nhóm các nhà thám hiểm du hành qua một hố đen ngoài vũ trụ để tìm kiếm sự sống mới cho nhân loại, đối mặt với sự cô đơn vô tận và những nghịch lý thời gian tàn nhẫn. Siêu phẩm của đạo diễn Christopher Nolan.
            </p>
            <div class="hero__actions" style="justify-content: flex-start; gap: 15px; margin-top: 25px;">
                <a asp-controller="Product" asp-action="Detail" asp-route-id="7" class="btn btn-red" style="background: #3b82f6; border-color: #3b82f6; padding: 12px 30px; border-radius: 8px; font-weight: 700; display: inline-flex; align-items: center; gap: 8px; text-decoration: none;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                    Phát Ngay
                </a>
                <button class="btn btn-ghost" style="border: 1px solid rgba(255, 255, 255, 0.3); padding: 12px 25px; border-radius: 8px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(5px);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M13 7h-2v4H7v2h4v4h2v-4h4v-2h-4V7zm-1-5C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" /></svg>
                    Lưu Xem Sau
                </button>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════
     FEATURED SINGLE MOVIES (HORIZON SCROLL)
     ══════════════════════════════════════ -->
<div class="trending movies-fade-in" style="padding-top: 40px; background: linear-gradient(to bottom, #0f172a, #020617);">
    <div class="trending__header" style="max-width: 1400px; margin: 0 auto; padding: 0 4%;">
        <h2 class="trending__title" style="font-size: 1.8rem; font-weight: 800; border-left: 4px solid #3b82f6; padding-left: 12px; letter-spacing: -0.5px;">Phim Lẻ Đề Cử</h2>
    </div>
    <div class="trending__track" id="moviesTrack" style="padding-left: 4%;">
        @foreach (var movie in Model.Take(4))
        {
            <a asp-controller="Product" asp-action="Detail" asp-route-id="@movie.Id" class="t-card" style="display: block; text-decoration: none; color: inherit;">
                <img class="t-card__img" src="@movie.ImageUrl" alt="@movie.Title" loading="lazy" />
                <div class="t-card__play" style="background: rgba(59, 130, 246, 0.9);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z" /></svg>
                </div>
                <div class="t-card__info" style="background: linear-gradient(to top, rgba(15, 23, 42, 0.95), rgba(15, 23, 42, 0.6));">
                    <div class="t-card__name">@movie.Title</div>
                    <div class="t-card__meta"><span class="t-card__genre" style="color: #60a5fa;">@movie.Genre</span>@movie.Year</div>
                </div>
            </a>
        }
    </div>
</div>

<!-- ══════════════════════════════════════
     ALL SINGLE MOVIES GRID (GLASSMORPHISM)
     ══════════════════════════════════════ -->
<section class="movies-grid-container movies-fade-in">
    <div class="movies-section-header">
        <div>
            <h2 class="movies-title">Khám Phá Phim Lẻ</h2>
            <p class="movies-subtitle">Tổng hợp siêu phẩm điện ảnh bom tấn chất lượng 4K đỉnh cao</p>
        </div>
    </div>

    <div class="movies-grid">
        @foreach (var movie in Model)
        {
            <div class="movies-card" onclick="window.location.href='@Url.Action("Detail", "Product", new { id = movie.Id })'">
                <div class="movies-card__img-container">
                    <img class="movies-card__img" src="@movie.ImageUrl" alt="@movie.Title" loading="lazy" />
                    <div class="movies-card__play-btn">
                        <svg width="22" height="22" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                    </div>
                </div>
                <div class="movies-card__content">
                    <h3 class="movies-card__title">@movie.Title</h3>
                    <div class="movies-card__info">
                        <span class="movies-card__genre">@movie.Genre</span>
                        <span class="movies-card__year">@movie.Year</span>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        /* Drag to scroll for Movies track */
        const track = document.getElementById('moviesTrack');
        if (track) {
            let isDown = false, startX, scrollLeft;
            track.addEventListener('mousedown', e => { 
                isDown = true; 
                track.classList.add('active'); 
                startX = e.pageX - track.offsetLeft; 
                scrollLeft = track.scrollLeft; 
            });
            track.addEventListener('mouseleave', () => { isDown = false; track.classList.remove('active'); });
            track.addEventListener('mouseup', () => { isDown = false; track.classList.remove('active'); });
            track.addEventListener('mousemove', e => {
                if (!isDown) return;
                e.preventDefault();
                const x = e.pageX - track.offsetLeft;
                const walk = (x - startX) * 2;
                track.scrollLeft = scrollLeft - walk;
            });
        }

        /* Navbar background transparency toggle on scroll */
        const nav = document.getElementById('nav');
        if (nav) {
            window.addEventListener('scroll', () => {
                if (window.scrollY > 50) nav.classList.add('scrolled');
                else nav.classList.remove('scrolled');
            }, { passive: true });
        }
    </script>
}
