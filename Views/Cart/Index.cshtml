@model List<CartItem>
@{
    ViewData["Title"] = "Giỏ Hàng - FILMIX";
}

<div class="cart-page" style="background: #141414; color: #fff; min-height: 100vh; padding: 120px 5% 80px 5%; font-family: 'Outfit', sans-serif;">
    <div class="cart-container" style="max-width: 1200px; margin: 0 auto;">
        
        <h1 style="font-size: 2.2rem; font-weight: 800; margin-bottom: 30px; display: flex; align-items: center; gap: 15px; border-left: 5px solid #e50914; padding-left: 15px;">
            Giỏ Hàng Của Bạn
        </h1>

        <div id="cart-content-wrapper" style="display: @(Model.Any() ? "grid" : "none"); grid-template-columns: 2.2fr 1fr; gap: 40px; align-items: start;">
            <!-- Cart Items List -->
            <div class="cart-items" style="display: grid; gap: 20px;">
                @foreach (var item in Model)
                {
                    <div class="cart-item-card" id="cart-item-@item.MovieId" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 20px; display: grid; grid-template-columns: auto 1fr auto; gap: 20px; align-items: center; backdrop-filter: blur(10px); transition: all 0.3s ease;">
                        
                        <!-- Movie Thumbnail -->
                        <div style="width: 120px; aspect-ratio: 16/9; border-radius: 8px; overflow: hidden; background: #2f2f2f; border: 1px solid rgba(255,255,255,0.1);">
                            <img src="@item.ImageUrl" alt="@item.MovieTitle" style="width: 100%; height: 100%; object-fit: cover;" />
                        </div>

                        <!-- Movie Info -->
                        <div style="display: grid; gap: 5px;">
                            <h3 style="margin: 0; font-size: 1.15rem; font-weight: 700; color: #fff;">@item.MovieTitle</h3>
                            <span style="font-size: 0.9rem; color: #999;">Đơn giá: <strong style="color: #46d369;">@item.Price.ToString("N0") VNĐ</strong></span>
                        </div>

                        <!-- Quantity Selector and Actions -->
                        <div style="display: flex; align-items: center; gap: 30px; flex-wrap: wrap;">
                            <!-- Quantity adjustment -->
                            <div style="display: flex; align-items: center; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; overflow: hidden;">
                                <button onclick="changeQty(@item.MovieId, -1)" style="background: transparent; border: none; color: #fff; width: 35px; height: 35px; font-size: 1.2rem; font-weight: 700; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.background='transparent'">−</button>
                                <span id="qty-@item.MovieId" style="width: 40px; text-align: center; font-weight: 700; font-size: 1rem;">@item.Quantity</span>
                                <button onclick="changeQty(@item.MovieId, 1)" style="background: transparent; border: none; color: #fff; width: 35px; height: 35px; font-size: 1.2rem; font-weight: 700; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.background='transparent'">+</button>
                            </div>

                            <!-- Item Total Price -->
                            <div style="min-width: 110px; text-align: right;">
                                <span id="total-@item.MovieId" style="font-size: 1.1rem; font-weight: 700; color: #46d369;">@item.TotalPrice.ToString("N0") VNĐ</span>
                            </div>

                            <!-- Delete Button -->
                            <button onclick="removeItem(@item.MovieId)" style="background: rgba(229, 9, 20, 0.1); border: 1px solid rgba(229, 9, 20, 0.2); color: #e50914; width: 35px; height: 35px; border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#e50914'; this.style.color='#fff';" onmouseout="this.style.background='rgba(229, 9, 20, 0.1)'; this.style.color='#e50914';">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                            </button>
                        </div>

                    </div>
                }
            </div>

            <!-- Checkout Info Card -->
            <div class="cart-summary" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 30px; backdrop-filter: blur(10px); display: grid; gap: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.4);">
                <h3 style="margin: 0; font-size: 1.3rem; font-weight: 700; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 15px;">
                    Thông Tin Đơn Hàng
                </h3>

                <div style="display: grid; gap: 12px; font-size: 0.95rem; color: #ccc;">
                    <div style="display: flex; justify-content: space-between;">
                        <span>Tạm tính</span>
                        <span id="summary-subtotal">@ViewBag.Subtotal.ToString("N0") VNĐ</span>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span>Thuế VAT (10%)</span>
                        <span id="summary-tax">@ViewBag.Tax.ToString("N0") VNĐ</span>
                    </div>
                    <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.1); margin: 5px 0;" />
                    <div style="display: flex; justify-content: space-between; font-size: 1.2rem; font-weight: 800; color: #fff;">
                        <span>Tổng cộng</span>
                        <span id="summary-total" style="color: #46d369;">@ViewBag.Total.ToString("N0") VNĐ</span>
                    </div>
                </div>

                <button onclick="checkout()" class="checkout-btn" style="background: #e50914; color: #fff; border: none; border-radius: 8px; padding: 14px; font-size: 1.05rem; font-weight: 700; cursor: pointer; transition: all 0.3s; text-align: center;">
                    Tiến Hành Thanh Toán
                </button>
                
                <a asp-controller="Home" asp-action="Index" style="text-align: center; color: #999; text-decoration: none; font-size: 0.9rem; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#999'">
                    ← Tiếp tục mua sắm
                </a>
            </div>
        </div>

        <!-- Empty Cart Fallback -->
        <div id="empty-cart-message" style="display: @(Model.Any() ? "none" : "flex"); flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 80px 20px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); border-radius: 16px; backdrop-filter: blur(10px);">
            <div style="background: rgba(229, 9, 20, 0.1); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; color: #e50914;">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            </div>
            <h2 style="font-size: 1.6rem; font-weight: 700; margin-bottom: 10px;">Giỏ hàng của bạn đang trống!</h2>
            <p style="color: #888; max-width: 400px; line-height: 1.5; margin-bottom: 30px;">
                Hãy quay lại trang chủ để lựa chọn những tựa phim và TV show đặc sắc nhất của FILMIX.
            </p>
            <a asp-controller="Home" asp-action="Index" style="background: #e50914; color: #fff; border: none; border-radius: 6px; padding: 12px 28px; font-size: 1rem; font-weight: 700; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.transform='scale(1.05)'; this.style.filter='brightness(1.1)';" onmouseout="this.style.transform='none'; this.style.filter='none';">
                Khám Phá Ngay
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Force header solid state
        const nav = document.getElementById('nav');
        if (nav) nav.classList.add('scrolled');

        function changeQty(movieId, change) {
            const qtySpan = document.getElementById(`qty-${movieId}`);
            let currentQty = parseInt(qtySpan.textContent);
            let newQty = currentQty + change;
            
            if (newQty <= 0) {
                // If quantity reaches 0, remove the item
                removeItem(movieId);
                return;
            }

            updateCartQty(movieId, newQty);
        }

        function updateCartQty(movieId, newQty) {
            $.ajax({
                url: `/api/cart/${movieId}`,
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify({ quantity: newQty }),
                success: function(response) {
                    if (response.success) {
                        // Update item quantity text
                        $(`#qty-${movieId}`).text(newQty);
                        // Update item total price
                        $(`#total-${movieId}`).text(response.itemTotal);
                        // Update order summary
                        updateSummary(response);
                        // Update nav badge
                        updateNavCartBadge(response.cartCount);
                        
                        showCartToast("Cập nhật giỏ hàng thành công!");
                    }
                },
                error: function() {
                    showCartToast("Không thể cập nhật số lượng!", true);
                }
            });
        }

        function removeItem(movieId) {
            if (!confirm("Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?")) return;

            $.ajax({
                url: `/api/cart/${movieId}`,
                type: 'DELETE',
                success: function(response) {
                    if (response.success) {
                        const card = document.getElementById(`cart-item-${movieId}`);
                        if (card) {
                            card.style.opacity = '0';
                            card.style.transform = 'translateY(15px)';
                            setTimeout(() => {
                                card.remove();
                                
                                // Check if cart is now empty
                                if (response.cartCount === 0) {
                                    document.getElementById('cart-content-wrapper').style.display = 'none';
                                    document.getElementById('empty-cart-message').style.display = 'flex';
                                }
                            }, 300);
                        }
                        
                        // Update summary & badge
                        updateSummary(response);
                        updateNavCartBadge(response.cartCount);
                        
                        showCartToast("Đã xóa sản phẩm khỏi giỏ hàng!");
                    }
                },
                error: function() {
                    showCartToast("Không thể xóa sản phẩm!", true);
                }
            });
        }

        function updateSummary(response) {
            document.getElementById('summary-subtotal').textContent = response.subtotal;
            document.getElementById('summary-tax').textContent = response.tax;
            document.getElementById('summary-total').textContent = response.total;
        }

        function updateNavCartBadge(count) {
            const badge = document.getElementById('nav-cart-badge');
            if (badge) {
                badge.textContent = count;
                badge.style.display = count > 0 ? 'flex' : 'none';
            }
        }

        function checkout() {
            window.location.href = '/Checkout';
        }

        function showCartToast(msg, isError = false) {
            let container = document.getElementById('toast-container');
            if (!container) {
                container = document.createElement('div');
                container.id = 'toast-container';
                container.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:99999;display:grid;gap:10px;';
                document.body.appendChild(container);
            }
            
            const toast = document.createElement('div');
            toast.style.cssText = `background:#2f2f2f;color:#fff;padding:12px 24px;border-radius:6px;font-weight:600;font-size:0.95rem;box-shadow:0 5px 15px rgba(0,0,0,0.3);animation: slideIn 0.3s ease, fadeOut 0.3s ease 2.7s forwards;border-left:4px solid ${isError ? '#e50914' : '#46d369'};`;
            toast.textContent = msg;
            
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>
    <style>
        .checkout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(229, 9, 20, 0.4);
            filter: brightness(1.1);
        }
        .cart-item-card:hover {
            background: rgba(255, 255, 255, 0.04) !important;
            border-color: rgba(255, 255, 255, 0.1) !important;
        }
    </style>
}
