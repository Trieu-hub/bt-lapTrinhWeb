@model IEnumerable<Movie>
@{
    ViewData["Title"] = "TV Shows - FILMIX";
}

<section class="hero hero--tv">
    <div class="hero__bg" style="background: linear-gradient(to right, rgba(0,0,0,0.8) 0%, transparent 60%), url('/images/auth/ap1.jpg') center/cover;"></div>
    <div class="hero__inner" style="align-items: flex-start; text-align: left; padding-left: 5%;">
        <div class="hero__content" style="max-width: 600px; margin-left: 0;">
            <div class="hero__badge">TV SERIES</div>
            <h1 class="hero__title" style="font-size: 5rem;">STRANGER<br><span class="red">THINGS</span></h1>
            <p class="hero__sub" style="margin-left: 0;">
                Khi một cậu bé mất tích, một thị trấn nhỏ phát hiện ra một bí ẩn liên quan đến các thí nghiệm bí mật, các lực lượng siêu nhiên đáng sợ và một cô bé kỳ lạ.
            </p>
            <div class="hero__actions" style="justify-content: flex-start;">
                <button class="btn btn-red">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                    Phát
                </button>
                <button class="btn btn-ghost">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M13 7h-2v4H7v2h4v4h2v-4h4v-2h-4V7zm-1-5C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" /></svg>
                    Danh sách của tôi
                </button>
            </div>
        </div>
    </div>
</section>

<div class="trending" style="padding-top: 20px;">
    <div class="trending__header">
        <h2 class="trending__title">TV Shows Phổ Biến</h2>
    </div>
    <div class="trending__track" id="tvTrack1">
        @foreach (var movie in Model)
        {
            <div class="t-card">
                <img class="t-card__img" src="@movie.ImageUrl" alt="@movie.Title" loading="lazy" />
                <div class="t-card__play">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z" /></svg>
                </div>
                <div class="t-card__info">
                    <div class="t-card__name">@movie.Title</div>
                    <div class="t-card__meta"><span class="t-card__genre">@movie.Genre</span>@movie.Year</div>
                </div>
            </div>
        }
    </div>

    </div>
</div>

@section Scripts {
    <script>
        /* Drag to scroll for TV tracks */
        document.querySelectorAll('.trending__track').forEach(tr => {
            let isDown = false, startX, sl;
            tr.addEventListener('mousedown', e => { isDown = true; tr.classList.add('active'); startX = e.pageX - tr.offsetLeft; sl = tr.scrollLeft; });
            tr.addEventListener('mouseleave', () => { isDown = false; tr.classList.remove('active'); });
            tr.addEventListener('mouseup', () => { isDown = false; tr.classList.remove('active'); });
            tr.addEventListener('mousemove', e => {
                if (!isDown) return;
                e.preventDefault();
                const x = e.pageX - tr.offsetLeft;
                const walk = (x - startX) * 2;
                tr.scrollLeft = sl - walk;
            });
        });

        /* Navbar effect */
        const nav = document.getElementById('nav');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) nav.classList.add('scrolled');
            else nav.classList.remove('scrolled');
        });
    </script>
}
