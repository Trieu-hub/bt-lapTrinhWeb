        let allMoviesOpen = false;

        function toggleAllMovies() {
            const wrap = document.getElementById('allMoviesWrap');
            const grid = document.getElementById('allMoviesGrid');
            const btn = document.getElementById('seeAllBtn');

            allMoviesOpen = !allMoviesOpen;

            if (allMoviesOpen) {
                if (!grid.children.length) {
                    grid.innerHTML = ALL_MOVIES.map((m, i) => `
                <a href="/Product/Detail/${m.num}" class="t-card" style="animation-delay:${i * 0.04}s; display: block; text-decoration: none; color: inherit;">
                  <img class="t-card__img" src="${m.img}" onerror="this.src='/images/movies/${m.num}.jpg'" alt="${m.title}" loading="lazy"/>
                  <span class="t-card__num">${m.num}</span>
                  <div class="t-card__play"><svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>
                  <div class="t-card__info">
                    <div class="t-card__name">${m.title}</div>
                    <div class="t-card__meta"><span class="t-card__genre">${m.genre}</span>${m.year}</div>
                  </div>
                </a>`).join('');
                }
                wrap.classList.add('open');
                btn.classList.add('expanded');
                // Lưu ý: t() là hàm từ i18n.js, tạm thời để text tĩnh nếu chưa có JS
                btn.innerHTML = `Thu Gọn <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>`;
                setTimeout(() => wrap.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
            } else {
                wrap.classList.remove('open');
                btn.classList.remove('expanded');
                btn.innerHTML = `Xem Tất Cả <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>`;
