        <img src="~/images/hero/hero1.jpg" alt="" />
        <img src="~/images/hero/hero2.jpg" alt="" />
        <img src="~/images/hero/hero3.jpg" alt="" />
        <img src="~/images/hero/hero4.jpg" alt="" />
        <img src="~/images/hero/hero5.jpg" alt="" />
        <img src="~/images/hero/hero6.jpg" alt="" />
        <img src="~/images/hero/hero7.jpg" alt="" />
        <img src="~/images/hero/hero8.jpg" alt="" />
    </div>

    <div class="hero__particles" id="particles" aria-hidden="true"></div>
    <div class="hero__overlay"></div>

    <div class="hero__inner">
        <div class="hero__content">
            <div class="hero__badge" data-i18n="hero.badge">Phim Mới Mỗi Tuần</div>
            <h1 class="hero__title">
                <span class="thin" data-i18n="hero.thin">Trải Nghiệm</span>
                <span data-i18n="hero.title">XEM PHIM</span><br><span class="red" data-i18n="hero.red">KHÔNG GIỚI HẠN</span>
            </h1>
            <p class="hero__sub" data-i18n="hero.sub">
                Hàng nghìn bộ phim, series nổi tiếng, anime &amp; tài liệu hấp dẫn —
                xem mọi lúc, mọi nơi, trên mọi thiết bị. Hủy bất cứ lúc nào.
            </p>
            <div class="hero__actions">
                <a asp-controller="Account" asp-action="Auth" asp-route-mode="signup" class="btn btn-red">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M8 5v14l11-7z" />
                    </svg>
                    <span data-i18n="hero.cta1">Đăng Ký Ngay</span>
                </a>
                <a href="#trending" class="btn btn-ghost" data-i18n="hero.cta2">Khám Phá Phim</a>
            </div>
        </div>

        <div class="hero__stats">
            <div class="hero__stat"><strong data-i18n="hero.stat1.n">10K+</strong><span data-i18n="hero.stat1.l">Nội
                    Dung</span></div>
            <div class="hero__stat"><strong data-i18n="hero.stat2.n">190+</strong><span data-i18n="hero.stat2.l">Quốc
                    Gia</span></div>
            <div class="hero__stat"><strong data-i18n="hero.stat3.n">4K</strong><span data-i18n="hero.stat3.l">Ultra
                    HD</span></div>
            <div class="hero__stat"><strong data-i18n="hero.stat4.n">30</strong><span data-i18n="hero.stat4.l">Ngày Miễn
                    Phí</span></div>
        </div>
    </div>

    <div class="hero__scroll" aria-label="Scroll">
        Scroll
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z" />
        </svg>
    </div>
</section>

