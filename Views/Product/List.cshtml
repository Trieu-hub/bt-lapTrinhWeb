@model IEnumerable<Movie>
@{
    ViewData["Title"] = "Danh Sách Phim";
    var categories = ViewBag.Categories as IEnumerable<Category> ?? [];
    int? selectedId = ViewBag.SelectedCategoryId;
}

<section class="trending" style="padding-top: 100px; min-height: 100vh;">
    <!-- Modern Netflix-style Tab Switcher -->
    <div class="list-tabs" style="display: flex; gap: 30px; border-bottom: 2px solid #222; margin-bottom: 30px; padding: 0 5%;">
        <button id="tabDiscover" class="tab-btn active" style="font-size: 1.5rem; font-weight: 700; color: white; background: none; border: none; padding-bottom: 12px; cursor: pointer; position: relative; transition: all 0.3s ease;">
            Khám Phá Phim
            <span class="active-indicator" style="position: absolute; bottom: -2px; left: 0; right: 0; height: 3px; background: var(--red); transition: all 0.3s ease;"></span>
        </button>
        <button id="tabMyList" class="tab-btn" style="font-size: 1.5rem; font-weight: 700; color: var(--gray); background: none; border: none; padding-bottom: 12px; cursor: pointer; position: relative; transition: all 0.3s ease;">
            Danh Sách Của Tôi
            <span class="active-indicator" style="position: absolute; bottom: -2px; left: 0; right: 0; height: 3px; background: transparent; transition: all 0.3s ease;"></span>
        </button>
    </div>

    <!-- 1. DISCOVER SECTION (Khám Phá Phim) -->
    <div id="discoverSection" class="tab-content active" style="animation: fadeIn 0.4s ease-out;">
        <div class="trending__header" style="flex-direction: column; align-items: flex-start; gap: 20px; padding: 0 5%;">
            <!-- Category Filter -->
            <div class="category-menu" style="display: flex; gap: 10px; flex-wrap: wrap;">
                <a asp-action="List" asp-route-categoryId="" 
                   class="btn @(selectedId == null ? "btn-red" : "btn-ghost")" style="padding: 8px 20px; font-size: 0.8rem;">
                   Tất Cả
                </a>
                @foreach (var cat in categories)
                {
                    <a asp-action="List" asp-route-categoryId="@cat.Id" 
                       class="btn @(selectedId == cat.Id ? "btn-red" : "btn-ghost")" style="padding: 8px 20px; font-size: 0.8rem;">
                       @cat.Name
                    </a>
                }
            </div>
        </div>

        <div class="trending__grid-wrap open" style="margin-top: 30px;">
            <div class="trending__grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(185px, 1fr)); gap: 20px; padding: 0 5%;">
                @if (!Model.Any())
                {
                    <p style="grid-column: 1/-1; text-align: center; color: var(--gray); padding: 50px;">Không tìm thấy phim nào trong danh mục này.</p>
                }
                @foreach (var movie in Model)
                {
                    <a asp-action="Detail" asp-route-id="@movie.Id" class="t-card" style="opacity: 1; transform: none; position: relative; display: block; text-decoration: none; color: inherit;">
                        <img class="t-card__img" src="@movie.ImageUrl" alt="@movie.Title" loading="lazy" />
                        <div class="t-card__play">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z" /></svg>
                        </div>
                        <div class="t-card__info">
                            <div class="t-card__name">@movie.Title</div>
                            <div class="t-card__meta"><span class="t-card__genre">@movie.Genre</span>@movie.Year</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- 2. MY LIST SECTION (Danh Sách Của Tôi) -->
    <div id="myListSection" class="tab-content" style="display: none; animation: fadeIn 0.4s ease-out;">
        <div class="trending__grid-wrap open" style="margin-top: 30px;">
            <div class="trending__grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(185px, 1fr)); gap: 20px; padding: 0 5%;">
                @* Render all movies as candidates for the Watchlist, filtered by JavaScript *@
                @foreach (var movie in Model)
                {
                    <a asp-action="Detail" asp-route-id="@movie.Id" data-mylist-id="@movie.Id" class="t-card mylist-card-item" style="display: none; opacity: 1; transform: none; position: relative; text-decoration: none; color: inherit;">
                        <img class="t-card__img" src="@movie.ImageUrl" alt="@movie.Title" loading="lazy" />
                        <div class="t-card__play">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z" /></svg>
                        </div>
                        <div class="t-card__info">
                            <div class="t-card__name">@movie.Title</div>
                            <div class="t-card__meta"><span class="t-card__genre">@movie.Genre</span>@movie.Year</div>
                        </div>
                    </a>
                }

                <!-- Watchlist Empty State -->
                <div id="emptyWatchlistMsg" style="display: none; grid-column: 1/-1; text-align: center; color: var(--gray); padding: 80px 20px;">
                    <div style="font-size: 4rem; margin-bottom: 20px; filter: drop-shadow(0 0 10px rgba(229, 9, 20, 0.4));">❤️</div>
                    <h3 style="color: white; margin-bottom: 12px; font-size: 1.5rem; font-weight: 600;">Danh sách của bạn đang trống</h3>
                    <p style="font-size: 0.95rem; max-width: 450px; margin: 0 auto; line-height: 1.6; color: #aaa;">Hãy nhấn nút <strong style="color: var(--red);">"Lưu Danh Sách"</strong> ở trang chi tiết của bộ phim bất kỳ để lưu lại và theo dõi tại đây nhé!</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const nav = document.getElementById('nav');
        nav.classList.add('scrolled'); // Force scrolled state for list page

        // Tab Switching Elements
        const tabDiscover = document.getElementById('tabDiscover');
        const tabMyList = document.getElementById('tabMyList');
        const discoverSection = document.getElementById('discoverSection');
        const myListSection = document.getElementById('myListSection');

        // Watchlist Filtering
        const myListCards = document.querySelectorAll('.mylist-card-item');
        const emptyMsg = document.getElementById('emptyWatchlistMsg');

        function updateMyListGrid() {
            // Read watchlist from localStorage
            let watchlist = JSON.parse(localStorage.getItem('filmix_watchlist') || '[]');
            watchlist = watchlist.map(id => id.toString());

            let visibleCount = 0;

            myListCards.forEach(card => {
                const movieId = card.dataset.mylistId;
                if (watchlist.includes(movieId)) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            if (visibleCount === 0) {
                emptyMsg.style.display = 'block';
            } else {
                emptyMsg.style.display = 'none';
            }
        }

        function switchTab(target) {
            if (target === 'discover') {
                // Active Discover Tab
                tabDiscover.classList.add('active');
                tabDiscover.style.color = 'white';
                tabDiscover.querySelector('.active-indicator').style.background = 'var(--red)';

                tabMyList.classList.remove('active');
                tabMyList.style.color = 'var(--gray)';
                tabMyList.querySelector('.active-indicator').style.background = 'transparent';

                discoverSection.style.display = 'block';
                myListSection.style.display = 'none';

                // Clear hash cleanly
                if (window.location.hash === '#watchlist') {
                    history.replaceState(null, null, ' ');
                }
            } else {
                // Active My List Tab
                tabMyList.classList.add('active');
                tabMyList.style.color = 'white';
                tabMyList.querySelector('.active-indicator').style.background = 'var(--red)';

                tabDiscover.classList.remove('active');
                tabDiscover.style.color = 'var(--gray)';
                tabDiscover.querySelector('.active-indicator').style.background = 'transparent';

                discoverSection.style.display = 'none';
                myListSection.style.display = 'block';

                // Populate grid dynamically
                updateMyListGrid();

                // Set hash
                window.location.hash = 'watchlist';
            }
        }

        // Tab click event listeners
        tabDiscover.addEventListener('click', () => switchTab('discover'));
        
        tabMyList.addEventListener('click', () => {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('categoryId')) {
                // Redirect to base list page with #watchlist to load all movies
                window.location.href = '@Url.Action("List", "Product")#watchlist';
            } else {
                switchTab('mylist');
            }
        });

        // Handle URL fragment on load
        window.addEventListener('load', () => {
            if (window.location.hash === '#watchlist') {
                switchTab('mylist');
            }
        });
    </script>
}
